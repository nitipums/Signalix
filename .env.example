# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# SET Trade Open API — market data
SETTRADE_APP_ID=your-app-id
SETTRADE_APP_SECRET=your-app-secret
SETTRADE_BROKER_ID=your-broker-id
SETTRADE_APP_CODE=your-app-code

# SET Trade Open API — trading credentials (required when TRADING_MODE=live)
SETTRADE_ACCOUNT_NO=your-equity-account-no
SETTRADE_PIN=your-account-pin

# Trading switches
TRADING_ENABLED=false                 # set to true on deploy after smoke test
TRADING_MODE=paper                    # "live" or "paper"

# Risk parameters
MIN_STRENGTH_SCORE=70
ALLOWED_PATTERNS=breakout,ath_breakout,vcp,vcp_low_cheat
RISK_PER_TRADE_PCT=0.01               # 1% of equity at risk per trade
REWARD_R_MULTIPLE=2.5                 # 2.5R target
MAX_POSITION_SIZE_THB=5000            # tiny cap for first deploy
MAX_OPEN_POSITIONS=1                  # tiny cap for first deploy
MAX_DAILY_LOSS_THB=2000
ENTRY_PRICE_TYPE=Limit                # "Limit" or "Market"
BOARD_LOT=100

# Internal security
SCAN_SECRET=your-internal-scan-secret

# App settings
ENVIRONMENT=development
LOG_LEVEL=INFO
